<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.project.platform.mapper.MovieOrderEvaluateMapper">
    <!-- 分页查询 -->
    <select id="queryPage"  resultType="com.project.platform.entity.MovieOrderEvaluate">
        SELECT movie_order_evaluate.*
               ,movie.name AS movieName
               ,user.username AS username
               ,user.avatar_url AS userAvatar
        FROM movie_order_evaluate
        LEFT JOIN movie ON movie_order_evaluate.movie_id=movie.id
        LEFT JOIN user ON movie_order_evaluate.user_id=user.id
        <include refid="queryConditions"/>
        ORDER BY movie_order_evaluate.id DESC
        LIMIT #{offset}, #{pageSize}
    </select>
    <!-- 查询总数 -->
    <select id="queryCount"  resultType="int">
        SELECT count(movie_order_evaluate.id) FROM movie_order_evaluate
        LEFT JOIN movie ON movie_order_evaluate.movie_id=movie.id
        LEFT JOIN user ON movie_order_evaluate.user_id=user.id
        <include refid="queryConditions"/>
    </select>

    <!-- 查询条件 -->
    <sql id="queryConditions">
        <where>
          <if test="query.userId != null and query.userId != 0">
            AND movie_order_evaluate.user_id = #{query.userId}
          </if>
          <if test="query.username != null and query.username.trim() != ''">
            AND user.username LIKE CONCAT('%', #{query.username}, '%')
          </if>
          <if test="query.movieId != null and query.movieId != 0">
            AND movie_order_evaluate.movie_id = #{query.movieId}
          </if>
          <if test="query.movieName != null and query.movieName.trim() != ''">
            AND movie.name LIKE CONCAT('%', #{query.movieName}, '%')
          </if>
          <if test="query.movieOrderId != null and query.movieOrderId != 0">
            AND movie_order_evaluate.movie_order_id = #{query.movieOrderId}
          </if>
          <if test="query.content != null and query.content.trim() != ''">
            AND movie_order_evaluate.content LIKE CONCAT('%', #{query.content}, '%')
          </if>
        </where>
    </sql>

    <!-- 插入 -->
    <insert id="insert" parameterType="com.project.platform.entity.MovieOrderEvaluate" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO movie_order_evaluate
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="movieId != null">movie_id,</if>
            <if test="movieOrderId != null">movie_order_id,</if>
            <if test="content != null">content,</if>
            <if test="rate != null">rate,</if>
            <if test="createTime != null">create_time,</if>
        </trim>
        VALUES
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="movieId != null">#{movieId},</if>
            <if test="movieOrderId != null">#{movieOrderId},</if>
            <if test="content != null">#{content},</if>
            <if test="rate != null">#{rate},</if>
            <if test="createTime != null">#{createTime},</if>
        </trim>


    </insert>

    <!-- 更新 -->
    <update id="updateById" parameterType="com.project.platform.entity.MovieOrderEvaluate">
        UPDATE movie_order_evaluate
        <set>
            <if test="userId != null">
             user_id = #{userId},
            </if>
            <if test="movieId != null">
             movie_id = #{movieId},
            </if>
            <if test="movieOrderId != null">
             movie_order_id = #{movieOrderId},
            </if>
            <if test="content != null">
             content = #{content},
            </if>
            <if test="rate != null">
             rate = #{rate},
            </if>
            <if test="createTime != null">
             create_time = #{createTime},
            </if>
        </set>
        WHERE id = #{id}
    </update>


    <!-- 根据ID列表删除 -->
    <delete id="removeByIds">
        DELETE FROM movie_order_evaluate
        WHERE id IN
        <foreach item="id" collection="list" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>    
</mapper>
