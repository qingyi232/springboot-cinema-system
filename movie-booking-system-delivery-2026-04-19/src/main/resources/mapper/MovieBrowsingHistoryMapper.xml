<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.project.platform.mapper.MovieBrowsingHistoryMapper">
    <!-- 分页查询 -->
    <select id="queryPage"  resultType="com.project.platform.entity.MovieBrowsingHistory">
        SELECT movie_browsing_history.*
               ,movie.name AS movieName
               ,movie.main_img AS movieMainImg
               ,user.username AS username
        FROM movie_browsing_history
        LEFT JOIN movie ON movie_browsing_history.movie_id=movie.id
        LEFT JOIN user ON movie_browsing_history.user_id=user.id
        <include refid="queryConditions"/>
        ORDER BY movie_browsing_history.id DESC
        LIMIT #{offset}, #{pageSize}
    </select>
    <!-- 查询总数 -->
    <select id="queryCount"  resultType="int">
        SELECT count(movie_browsing_history.id) FROM movie_browsing_history
        LEFT JOIN movie ON movie_browsing_history.movie_id=movie.id
        LEFT JOIN user ON movie_browsing_history.user_id=user.id
        <include refid="queryConditions"/>
    </select>

    <!-- 查询条件 -->
    <sql id="queryConditions">
        <where>
          <if test="query.movieId != null and query.movieId != 0">
            AND movie_browsing_history.movie_id = #{query.movieId}
          </if>
          <if test="query.movieName != null and query.movieName.trim() != ''">
            AND movie.name LIKE CONCAT('%', #{query.movieName}, '%')
          </if>
          <if test="query.userId != null and query.userId != 0">
            AND movie_browsing_history.user_id = #{query.userId}
          </if>
          <if test="query.username != null and query.username.trim() != ''">
            AND user.username LIKE CONCAT('%', #{query.username}, '%')
          </if>
        </where>
    </sql>

    <!-- 插入 -->
    <insert id="insert" parameterType="com.project.platform.entity.MovieBrowsingHistory" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO movie_browsing_history
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="movieId != null">movie_id,</if>
            <if test="userId != null">user_id,</if>
            <if test="createTime != null">create_time,</if>
        </trim>
        VALUES
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="movieId != null">#{movieId},</if>
            <if test="userId != null">#{userId},</if>
            <if test="createTime != null">#{createTime},</if>
        </trim>


    </insert>

    <!-- 更新 -->
    <update id="updateById" parameterType="com.project.platform.entity.MovieBrowsingHistory">
        UPDATE movie_browsing_history
        <set>
            <if test="movieId != null">
             movie_id = #{movieId},
            </if>
            <if test="userId != null">
             user_id = #{userId},
            </if>
            <if test="createTime != null">
             create_time = #{createTime},
            </if>
        </set>
        WHERE id = #{id}
    </update>


    <!-- 根据ID列表删除 -->
    <delete id="removeByIds">
        DELETE FROM movie_browsing_history
        WHERE id IN
        <foreach item="id" collection="list" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>    
</mapper>
