<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.project.platform.mapper.MovieOrderMapper">
    <select id="queryPage" resultType="com.project.platform.entity.MovieOrder">
        SELECT movie_order.*
               ,movie.name AS movieName
               ,movie_room.name AS movieRoomName
               ,movie.main_img AS movieMainImg
               ,cinema.nickname AS cinemaName
               ,user.username AS userName
        FROM movie_order
        LEFT JOIN movie ON movie_order.movie_id = movie.id
        LEFT JOIN movie_room ON movie_order.movie_room_id = movie_room.id
        LEFT JOIN cinema ON movie_order.cinema_id = cinema.id
        LEFT JOIN user ON movie_order.user_id = user.id
        <include refid="queryConditions"/>
        ORDER BY movie_order.id DESC
        LIMIT #{offset}, #{pageSize}
    </select>

    <select id="queryCount" resultType="int">
        SELECT count(movie_order.id)
        FROM movie_order
        LEFT JOIN movie ON movie_order.movie_id = movie.id
        LEFT JOIN movie_room ON movie_order.movie_room_id = movie_room.id
        LEFT JOIN cinema ON movie_order.cinema_id = cinema.id
        LEFT JOIN user ON movie_order.user_id = user.id
        <include refid="queryConditions"/>
    </select>

    <sql id="queryConditions">
        <where>
            <if test="query.cinemaId != null and query.cinemaId != 0">
                AND movie_order.cinema_id = #{query.cinemaId}
            </if>
            <if test="query.screeningPlanId != null and query.screeningPlanId != 0">
                AND movie_order.screening_plan_id = #{query.screeningPlanId}
            </if>
            <if test="query.status != null and query.status.trim() != ''">
                AND movie_order.status = #{query.status}
            </if>
            <if test="query.paymentMethod != null and query.paymentMethod.trim() != ''">
                AND movie_order.payment_method = #{query.paymentMethod}
            </if>
            <if test="query.ticketCode != null and query.ticketCode.trim() != ''">
                AND movie_order.ticket_code = #{query.ticketCode}
            </if>
            <if test="query.userId != null and query.userId != 0">
                AND movie_order.user_id = #{query.userId}
            </if>
        </where>
    </sql>

    <insert id="insert" parameterType="com.project.platform.entity.MovieOrder" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO movie_order
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="cinemaId != null">cinema_id,</if>
            <if test="movieRoomId != null">movie_room_id,</if>
            <if test="movieId != null">movie_id,</if>
            <if test="startTime != null">start_time,</if>
            <if test="endTime != null">end_time,</if>
            <if test="price != null">price,</if>
            <if test="numberOfX != null">number_of_x,</if>
            <if test="numberOfY != null">number_of_y,</if>
            <if test="screeningPlanId != null">screening_plan_id,</if>
            <if test="status != null">status,</if>
            <if test="paymentMethod != null and paymentMethod.trim() != ''">payment_method,</if>
            <if test="reserveExpireTime != null">reserve_expire_time,</if>
            <if test="ticketCode != null and ticketCode.trim() != ''">ticket_code,</if>
            <if test="verifyTime != null">verify_time,</if>
            <if test="userId != null">user_id,</if>
        </trim>
        VALUES
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="cinemaId != null">#{cinemaId},</if>
            <if test="movieRoomId != null">#{movieRoomId},</if>
            <if test="movieId != null">#{movieId},</if>
            <if test="startTime != null">#{startTime},</if>
            <if test="endTime != null">#{endTime},</if>
            <if test="price != null">#{price},</if>
            <if test="numberOfX != null">#{numberOfX},</if>
            <if test="numberOfY != null">#{numberOfY},</if>
            <if test="screeningPlanId != null">#{screeningPlanId},</if>
            <if test="status != null">#{status},</if>
            <if test="paymentMethod != null and paymentMethod.trim() != ''">#{paymentMethod},</if>
            <if test="reserveExpireTime != null">#{reserveExpireTime},</if>
            <if test="ticketCode != null and ticketCode.trim() != ''">#{ticketCode},</if>
            <if test="verifyTime != null">#{verifyTime},</if>
            <if test="userId != null">#{userId},</if>
        </trim>
    </insert>

    <update id="updateById" parameterType="com.project.platform.entity.MovieOrder">
        UPDATE movie_order
        <set>
            <if test="cinemaId != null">cinema_id = #{cinemaId},</if>
            <if test="movieRoomId != null">movie_room_id = #{movieRoomId},</if>
            <if test="movieId != null">movie_id = #{movieId},</if>
            <if test="startTime != null">start_time = #{startTime},</if>
            <if test="endTime != null">end_time = #{endTime},</if>
            <if test="price != null">price = #{price},</if>
            <if test="numberOfX != null">number_of_x = #{numberOfX},</if>
            <if test="numberOfY != null">number_of_y = #{numberOfY},</if>
            <if test="screeningPlanId != null">screening_plan_id = #{screeningPlanId},</if>
            <if test="status != null">status = #{status},</if>
            order_evaluate_id = #{orderEvaluateId},
            payment_method = #{paymentMethod},
            reserve_expire_time = #{reserveExpireTime},
            ticket_code = #{ticketCode},
            verify_time = #{verifyTime},
            <if test="userId != null">user_id = #{userId},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="removeByIds">
        DELETE FROM movie_order
        WHERE id IN
        <foreach item="id" collection="list" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
