<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.project.platform.mapper.GoodsMapper">
    <select id="queryPage" resultType="com.project.platform.entity.Goods">
        SELECT goods.*
        FROM goods
        <include refid="queryConditions"/>
        ORDER BY goods.id DESC
        LIMIT #{offset}, #{pageSize}
    </select>

    <select id="queryCount" resultType="int">
        SELECT COUNT(goods.id)
        FROM goods
        <include refid="queryConditions"/>
    </select>

    <sql id="queryConditions">
        <where>
            <if test="query.name != null and query.name.trim() != ''">
                AND goods.name LIKE CONCAT('%', #{query.name}, '%')
            </if>
            <if test="query.category != null and query.category.trim() != ''">
                AND goods.category = #{query.category}
            </if>
            <if test="query.status != null and query.status.trim() != ''">
                AND goods.status = #{query.status}
            </if>
        </where>
    </sql>

    <insert id="insert" parameterType="com.project.platform.entity.Goods" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO goods
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null">name,</if>
            <if test="mainImg != null">main_img,</if>
            <if test="category != null">category,</if>
            <if test="price != null">price,</if>
            <if test="stock != null">stock,</if>
            <if test="status != null">status,</if>
            <if test="intro != null">intro,</if>
            <if test="createTime != null">create_time,</if>
        </trim>
        VALUES
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null">#{name},</if>
            <if test="mainImg != null">#{mainImg},</if>
            <if test="category != null">#{category},</if>
            <if test="price != null">#{price},</if>
            <if test="stock != null">#{stock},</if>
            <if test="status != null">#{status},</if>
            <if test="intro != null">#{intro},</if>
            <if test="createTime != null">#{createTime},</if>
        </trim>
    </insert>

    <update id="updateById" parameterType="com.project.platform.entity.Goods">
        UPDATE goods
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="mainImg != null">main_img = #{mainImg},</if>
            <if test="category != null">category = #{category},</if>
            <if test="price != null">price = #{price},</if>
            <if test="stock != null">stock = #{stock},</if>
            <if test="status != null">status = #{status},</if>
            <if test="intro != null">intro = #{intro},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="removeByIds">
        DELETE FROM goods
        WHERE id IN
        <foreach item="id" collection="list" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
