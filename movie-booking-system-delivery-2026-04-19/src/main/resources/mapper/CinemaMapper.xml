<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.project.platform.mapper.CinemaMapper">
    <!-- 分页查询 -->
    <select id="queryPage"  resultType="com.project.platform.entity.Cinema">
        SELECT cinema.*
        FROM cinema
        <include refid="queryConditions"/>
        ORDER BY cinema.id DESC
        LIMIT #{offset}, #{pageSize}
    </select>
    <!-- 查询总数 -->
    <select id="queryCount"  resultType="int">
        SELECT count(cinema.id) FROM cinema
        <include refid="queryConditions"/>
    </select>

    <!-- 查询条件 -->
    <sql id="queryConditions">
        <where>
          <if test="query.username != null and query.username.trim() != ''">
            AND cinema.username LIKE CONCAT('%', #{query.username}, '%')
          </if>
          <if test="query.tel != null and query.tel.trim() != ''">
            AND cinema.tel LIKE CONCAT('%', #{query.tel}, '%')
          </if>
          <if test="query.status != null and query.status.trim() != ''">
            AND cinema.status = #{query.status}
          </if>
        </where>
    </sql>

    <!-- 插入 -->
    <insert id="insert" parameterType="com.project.platform.entity.Cinema" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO cinema
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="username != null">username,</if>
            <if test="password != null">password,</if>
            <if test="nickname != null">nickname,</if>
            <if test="avatarUrl != null">avatar_url,</if>
            <if test="tel != null">tel,</if>
            <if test="email != null">email,</if>
            <if test="status != null">status,</if>
            <if test="address != null">address,</if>
            <if test="label != null">label,</if>
        </trim>
        VALUES
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="username != null">#{username},</if>
            <if test="password != null">#{password},</if>
            <if test="nickname != null">#{nickname},</if>
            <if test="avatarUrl != null">#{avatarUrl},</if>
            <if test="tel != null">#{tel},</if>
            <if test="email != null">#{email},</if>
            <if test="status != null">#{status},</if>
            <if test="address != null">#{address},</if>
            <if test="label != null">#{label},</if>
        </trim>


    </insert>

    <!-- 更新 -->
    <update id="updateById" parameterType="com.project.platform.entity.Cinema">
        UPDATE cinema
        <set>
            <if test="username != null">
             username = #{username},
            </if>
            <if test="password != null">
             password = #{password},
            </if>
            <if test="nickname != null">
             nickname = #{nickname},
            </if>
            <if test="avatarUrl != null">
             avatar_url = #{avatarUrl},
            </if>
            <if test="tel != null">
             tel = #{tel},
            </if>
            <if test="email != null">
             email = #{email},
            </if>
            <if test="status != null">
             status = #{status},
            </if>
            <if test="address != null">
             address = #{address},
            </if>
            <if test="label != null">
             label = #{label},
            </if>
        </set>
        WHERE id = #{id}
    </update>


    <!-- 根据ID列表删除 -->
    <delete id="removeByIds">
        DELETE FROM cinema
        WHERE id IN
        <foreach item="id" collection="list" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>    
</mapper>
